{
  "name": "vpn-app",
  "version": "1.0.0",
  "description": "Cross-platform VPN application with multi-protocol support",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace VPNApp.xcworkspace -scheme VPNApp -configuration Release",
    "web": "react-scripts start",
    "build:web": "react-scripts build"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.6",
    "react-native-maps": "^1.7.1",
    "react-native-vector-icons": "^10.0.0",
    "react-native-svg": "^13.14.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "^3.5.4",
    "react-native-gesture-handler": "^2.12.1",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-screens": "^3.25.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@supabase/supabase-js": "^2.38.4",
    "axios": "^1.6.2",
    "react-native-async-storage": "^1.19.5",
    "react-native-device-info": "^10.11.0",
    "react-native-permissions": "^3.10.1",
    "react-native-background-timer": "^2.4.1",
    "react-native-vpn": "^1.0.0",
    "react-native-netinfo": "^11.2.1",
    "react-native-push-notification": "^8.1.1",
    "react-native-sound": "^0.11.2",
    "react-native-haptic-feedback": "^2.1.0",
    "react-native-share": "^9.4.1",
    "react-native-fs": "^2.20.0",
    "react-native-config": "^1.5.1",
    "react-native-dotenv": "^3.4.9"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4",
    "tailwindcss": "^3.3.6",
    "nativewind": "^2.0.11"
  },
  "jest": {
    "preset": "react-native"
  }
}
